<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <SimManagementLib.SimDef.ShopStaffRoleDef>
    <defName>SimShopRole_Cashier</defName>
    <label>收银</label>
    <description>负责收银台值班和店内收银相关工作。</description>
    <maxAssignedPawns>2</maxAssignedPawns>
    <requiredThingClasses>
      <li>SimManagementLib.SimThingClass.Building_CashRegister</li>
    </requiredThingClasses>
    <workGivers>
      <li>Sim_WorkGiver_ManCashRegister</li>
    </workGivers>
    <jobDefs>
      <li>Sim_ManCashRegister</li>
    </jobDefs>
  </SimManagementLib.SimDef.ShopStaffRoleDef>

  <SimManagementLib.SimDef.ShopStaffRoleDef>
    <defName>SimShopRole_Restocker</defName>
    <label>补货</label>
    <description>负责货柜补货和货柜库存整理工作。</description>
    <maxAssignedPawns>3</maxAssignedPawns>
    <requiredThingClasses>
      <li>SimManagementLib.SimThingClass.Building_SimContainer</li>
    </requiredThingClasses>
    <workGivers>
      <li>RestockMegaStorage</li>
      <li>WithdrawFromMegaStorage</li>
    </workGivers>
    <jobDefs>
      <li>DepositToMegaStorage</li>
      <li>WithdrawFromMegaStorage</li>
    </jobDefs>
  </SimManagementLib.SimDef.ShopStaffRoleDef>
</Defs>
