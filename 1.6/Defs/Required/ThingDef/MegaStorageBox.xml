<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <ThingDef Name="MegaStorageBox" ParentName="BuildingBase" Abstract="True">
        <thingClass>SimManagementLib.SimThingClass.Building_SimContainer</thingClass>
        <graphicData>
            <graphicClass>Graphic_Multi</graphicClass>
        </graphicData>
        <altitudeLayer>Building</altitudeLayer>
        <passability>PassThroughOnly</passability>
        <pathCost>50</pathCost>
        <fillPercent>0.4</fillPercent>
        <castEdgeShadows>true</castEdgeShadows>
        <staticSunShadowHeight>0.5</staticSunShadowHeight>
        <drawerType>MapMeshOnly</drawerType>
        <selectable>true</selectable>
        <leaveResourcesWhenKilled>true</leaveResourcesWhenKilled>
        <noRightClickDraftAttack>true</noRightClickDraftAttack>
        <surfaceType>Item</surfaceType>
        <category>Building</category>
        <filthLeaving>Filth_RubbleBuilding</filthLeaving>
        <repairEffect>Repair</repairEffect>
        <soundImpactDefault>BulletImpact_Metal</soundImpactDefault>
        <defaultPlacingRot>South</defaultPlacingRot>
        <canOverlapZones>true</canOverlapZones>
        <statBases>
            <MaxHitPoints>100</MaxHitPoints>
            <WorkToBuild>500</WorkToBuild>
            <Mass>5</Mass>
            <Flammability>0.5</Flammability>
            <Beauty>6</Beauty>
            <SellPriceFactor>0.7</SellPriceFactor>
        </statBases>
        <terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
        <designationCategory>SimManagementBuildings</designationCategory>
        <building>
            <maxItemsInCell>999</maxItemsInCell>
            <preventDeteriorationOnTop>true</preventDeteriorationOnTop>
            <ignoreStoredThingsBeauty>true</ignoreStoredThingsBeauty>
            <blueprintClass>Blueprint_Storage</blueprintClass>
            <!-- 这部分是硬限制，避免存入明显不合适的物品。 -->
            <fixedStorageSettings>
                <filter>
                    <disallowNotEverStorable>true</disallowNotEverStorable>
                    <categories>
                        <li>Root</li>
                    </categories>
                    <disallowedCategories>
                        <li>Chunks</li>
                        <li>Plants</li>
                        <li>Buildings</li>
                    </disallowedCategories>
                    <specialFiltersToDisallow>
                        <li>AllowLargeCorpses</li>
                    </specialFiltersToDisallow>
                </filter>
            </fixedStorageSettings>
            <!-- 这部分是默认筛选，玩家可以在游戏里继续调整。 -->
            <defaultStorageSettings>
                <priority>Preferred</priority>
                <filter>
                    <categories>
                        <li>Foods</li>
                        <li>Manufactured</li>
                        <li>ResourcesRaw</li>
                        <li>Items</li>
                        <li>Weapons</li>
                        <li>Apparel</li>
                        <li>BodyParts</li>
                    </categories>
                </filter>
            </defaultStorageSettings>
        </building>
        <minifiedDef>MinifiedThing</minifiedDef>
        <thingCategories>
            <li>BuildingsFurniture</li>
        </thingCategories>
    </ThingDef>

    <!-- 默认货柜。开发者可以复制这个 ThingDef 做小型/中型/精致货柜。 -->
    <ThingDef ParentName="MegaStorageBox">
        <defName>BigStorageBox</defName>
        <label>大货柜</label>
        <description>用于商店运营的大货柜。可集中存放并管理店铺售卖物资，方便补货与结算。</description>
        <graphicData>
            <texPath>Things/Building/MegaStorageBox/BigStorageBox</texPath>
            <drawSize>(2.8, 2.8)</drawSize>
            <drawOffsetSouth>(0, 0.1, 0.19)</drawOffsetSouth>
            <drawOffsetNorth>(0, 0.1, 0.19)</drawOffsetNorth>
            <drawOffsetEast>(0, 0.1, 0.35)</drawOffsetEast>
            <drawOffsetWest>(0, 0.1, 0.35)</drawOffsetWest>
        </graphicData>
        <size>(2, 1)</size>
        <costList>
            <Steel>15</Steel>
        </costList>
        <comps>
            <li Class="SimManagementLib.SimThingComp.ThingCompProperties_GoodsData">
            <!-- 货柜总容量上限（按件数，跨所有商品共享） -->
            <maxTotalCapacity>900</maxTotalCapacity>
            </li>
        </comps>
    </ThingDef>

