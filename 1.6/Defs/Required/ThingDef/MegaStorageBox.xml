    <ThingDef ParentName="MegaStorageBox">
        <defName>BeverageMachineA</defName>
        <label>饮料机A</label>
        <description>用于商店运营的饮料机。可集中存放并管理店铺售卖的饮料，方便补货与结算。</description>
        <graphicData>
            <texPath>Things/Building/MegaStorageBox/BeverageMachineA</texPath>
            <drawSize>(2.65, 2.65)</drawSize>
            <drawOffsetSouth>(0, 0.1, 0.25)</drawOffsetSouth>
            <drawOffsetNorth>(0, 0.1, 0.25)</drawOffsetNorth>
            <drawOffsetEast>(-0.2, 0.1, 0.465)</drawOffsetEast>
            <drawOffsetWest>(0.2, 0.1, 0.465)</drawOffsetWest>
        </graphicData>
        <size>(1, 1)</size>
        <costList>
            <Steel>15</Steel>
        </costList>
        <comps>
            <li Class="SimManagementLib.SimThingComp.ThingCompProperties_GoodsData">
            <!-- 货柜总容量上限（按件数，跨所有商品共享） -->
            <maxTotalCapacity>300</maxTotalCapacity>
            </li>
            <li Class="CompProperties_Forbiddable"/>
            <li Class="CompProperties_Power">
                <compClass>CompPowerTrader</compClass>
                <basePowerConsumption>70</basePowerConsumption>
            </li>
            <li Class="CompProperties_Flickable"/>
            <li Class="CompProperties_Schedule">
            <!-- Match plant growing times -->
                <startTime>0.25</startTime>
                <endTime>0.8</endTime>
                <offMessage>Off for plant resting period</offMessage>
            </li>
            <li Class="CompProperties_Glower">
                <overlightRadius>7.0</overlightRadius>
                <glowRadius>3</glowRadius>
                <glowColor>(370,370,370,0)</glowColor>
            </li>
        </comps>
    </ThingDef>

