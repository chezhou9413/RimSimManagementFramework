<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <ThingDef ParentName="BuildingBase">
        <defName>RSMF_Collections_Piano</defName>
        <label>斯坦福钢琴</label>
        <description>非常，非常，非常昂贵的钢琴，真的非常昂贵，但用其演奏出来的效果绝对值得她的价钱</description>
        <graphicData>
            <texPath>Things/Collection/Piano/Piano</texPath>
            <graphicClass>Graphic_Multi</graphicClass>
            <drawSize>(3.6,3.6)</drawSize>
        </graphicData>
        <size>(3,3)</size>
        <interactionCellOffset>(0,0,2)</interactionCellOffset>
        <soundPlayInstrument>Piano_Play</soundPlayInstrument>
        <altitudeLayer>Building</altitudeLayer>
        <rotatable>true</rotatable>
        <thingClass>Building_MusicalInstrument</thingClass>
        <passability>PassThroughOnly</passability>
        <pathCost>50</pathCost>
        <tickerType>Normal</tickerType>
        <minifiedDef>MinifiedThing</minifiedDef>
        <socialPropernessMatters>true</socialPropernessMatters>
        <hasInteractionCell>true</hasInteractionCell>
        <thingCategories>
            <li>BuildingsJoy</li>
        </thingCategories>
        <statBases>
            <MaxHitPoints>200</MaxHitPoints>
            <WorkToMake>100</WorkToMake>
            <Mass>60</Mass>
            <JoyGainFactor>2</JoyGainFactor>
            <Beauty>25</Beauty>
        </statBases>
        <building>
            <instrumentRange>20</instrumentRange>
            <joyKind>HighCulture</joyKind>
        </building>
        <comps>
            <li>
                <compClass>CompQuality</compClass>
            </li>
            <li>
                <compClass>CompGatherSpot</compClass>
            </li>
            <li Class="CompProperties_ThrownFleckEmitter">
                <fleck>Music</fleck>
                <offsetMin>(-0.6,0,0.3)</offsetMin>
                <offsetMax>(0.6,0,0.5)</offsetMax>
                <emissionInterval>100</emissionInterval>
                <scale>0.6~0.9</scale>
                <rotationRate>-15~15</rotationRate>
                <velocityX>0.3~0.7</velocityX>
                <velocityY>0.7~1.0</velocityY>
            </li>
        </comps>
        <placeWorkers>
            <li>PlaceWorker_ShowInstrumentAoE</li>
        </placeWorkers>
    </ThingDef>

