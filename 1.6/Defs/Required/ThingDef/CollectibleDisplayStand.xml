<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingDef ParentName="BuildingBase">
    <defName>RSMF_CollectibleDisplayStand</defName>
    <label>收藏品展台</label>
    <description>用于展示模拟经营框架收藏品的大型展台。可通过管理面板配置多个展示槽位，并让小人把地图上的收藏品搬运到展台上。</description>
    <thingClass>SimManagementLib.SimThingClass.Building_CollectibleDisplayStand</thingClass>
    <graphicData>
      <texPath>Things/Building/CollectibleDisplayStand/CollectibleDisplayStand</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawRotated>false</drawRotated>
      <drawSize>(5,5)</drawSize>
    </graphicData>
    <size>(5,5)</size>
    <altitudeLayer>Building</altitudeLayer>
    <rotatable>false</rotatable>
    <passability>PassThroughOnly</passability>
    <pathCost>50</pathCost>
    <fillPercent>0.20</fillPercent>
    <drawerType>RealtimeOnly</drawerType>
    <selectable>true</selectable>
    <leaveResourcesWhenKilled>true</leaveResourcesWhenKilled>
    <noRightClickDraftAttack>true</noRightClickDraftAttack>
    <surfaceType>Item</surfaceType>
    <category>Building</category>
    <filthLeaving>Filth_RubbleBuilding</filthLeaving>
    <repairEffect>Repair</repairEffect>
    <soundImpactDefault>BulletImpact_Metal</soundImpactDefault>
    <defaultPlacingRot>South</defaultPlacingRot>
    <canOverlapZones>true</canOverlapZones>
    <hasInteractionCell>true</hasInteractionCell>
    <interactionCellOffset>(0,0,-3)</interactionCellOffset>
    <terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
    <designationCategory>SimManagementBuildings</designationCategory>
    <minifiedDef>MinifiedThing</minifiedDef>
    <thingCategories>
      <li>BuildingsFurniture</li>
    </thingCategories>
    <statBases>
      <MaxHitPoints>260</MaxHitPoints>
      <WorkToBuild>650</WorkToBuild>
      <Mass>18</Mass>
      <Flammability>0.4</Flammability>
      <Beauty>12</Beauty>
      <SellPriceFactor>0.7</SellPriceFactor>
    </statBases>
    <costList>
      <Steel>80</Steel>
      <WoodLog>40</WoodLog>
    </costList>
    <building>
      <maxItemsInCell>999</maxItemsInCell>
      <preventDeteriorationOnTop>true</preventDeteriorationOnTop>
      <ignoreStoredThingsBeauty>true</ignoreStoredThingsBeauty>
    </building>
    <comps>
      <li Class="SimManagementLib.SimThingComp.CompProperties_CollectibleDisplayStand">
        <rows>2</rows>
        <columns>3</columns>
        <defaultHeight>0.08</defaultHeight>
        <defaultScale>1</defaultScale>
        <defaultRotation>0</defaultRotation>
        <slotDefaults>
          <li><index>0</index><offsetX>-1.293</offsetX><offsetZ>-0.17</offsetZ><height>0.08</height><scale>1</scale><rotation>-180</rotation></li>
          <li><index>1</index><offsetX>-0.51</offsetX><offsetZ>0.323</offsetZ><height>0.08</height><scale>1</scale><rotation>180</rotation></li>
          <li><index>2</index><offsetX>1.25</offsetX><offsetZ>-0.051</offsetZ><height>0.08</height><scale>1</scale><rotation>180</rotation></li>
          <li><index>3</index><offsetX>0.544</offsetX><offsetZ>0.221</offsetZ><height>0.08</height><scale>1</scale><rotation>180</rotation></li>
          <li><index>4</index><offsetX>0.102</offsetX><offsetZ>1.293</offsetZ><height>0.08</height><scale>1</scale><rotation>180</rotation></li>
          <li><index>5</index><offsetX>-0.017</offsetX><offsetZ>1.99</offsetZ><height>0.08</height><scale>1</scale><rotation>180</rotation></li>
        </slotDefaults>
      </li>
      <li Class="SimManagementLib.SimThingComp.CompProperties_ServiceProvider">
        <defaultServiceDefNames>
          <li>Sim_Service_CollectibleDisplayStandVisit</li>
        </defaultServiceDefNames>
        <defaultMaxSimultaneousUsers>3</defaultMaxSimultaneousUsers>
        <enabledByDefault>true</enabledByDefault>
      </li>
    </comps>
    <placeWorkers>
      <li>PlaceWorker_PreventInteractionSpotOverlap</li>
    </placeWorkers>
  </ThingDef>
</Defs>
