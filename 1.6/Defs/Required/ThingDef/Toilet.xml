<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <!-- 付费厕所服务建筑。当前复用原版凳子贴图，后续可替换为专用马桶贴图。 -->
  <ThingDef ParentName="BuildingBase">
    <defName>Sim_Toilet</defName>
    <label>马桶</label>
    <description>提供收费厕所服务的商店建筑。顾客付款后会在这里停留一段时间完成服务。</description>
    <thingClass>Building</thingClass>
    <graphicData>
      <texPath>Things/Building/Toilet/Toilet</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(1.6, 1.6)</drawSize>
      <damageData>
        <cornerTL>Damage/Corner</cornerTL>
        <cornerTR>Damage/Corner</cornerTR>
        <cornerBL>Damage/Corner</cornerBL>
        <cornerBR>Damage/Corner</cornerBR>
      </damageData>
      <shadowData>
        <volume>(0.18, 0.23, 0.18)</volume>
      </shadowData>
    </graphicData>
    <altitudeLayer>Building</altitudeLayer>
    <defaultPlacingRot>South</defaultPlacingRot>
    <drawerType>MapMeshOnly</drawerType>
    <category>Building</category>
    <designationCategory>SimManagementBuildings</designationCategory>
    <designationHotKey>Misc6</designationHotKey>
    <selectable>true</selectable>
    <leaveResourcesWhenKilled>true</leaveResourcesWhenKilled>
    <minifiedDef>MinifiedThing</minifiedDef>
    <canOverlapZones>true</canOverlapZones>
    <hasInteractionCell>true</hasInteractionCell>
    <interactionCellOffset>(0,0,1)</interactionCellOffset>
    <fillPercent>0.2</fillPercent>
    <pathCost>30</pathCost>
    <passability>Standable</passability>
    <terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
    <filthLeaving>Filth_RubbleBuilding</filthLeaving>
    <repairEffect>Repair</repairEffect>
    <soundImpactDefault>BulletImpact_Metal</soundImpactDefault>
    <statBases>
      <MaxHitPoints>75</MaxHitPoints>
      <WorkToBuild>450</WorkToBuild>
      <Mass>3</Mass>
      <Flammability>1</Flammability>
      <Beauty>0</Beauty>
      <SellPriceFactor>0.7</SellPriceFactor>
    </statBases>
    <costList>
      <Steel>25</Steel>
    </costList>
    <thingCategories>
      <li>BuildingsFurniture</li>
    </thingCategories>
    <building>
      <isEdifice>false</isEdifice>
    </building>
    <comps>
      <li Class="SimManagementLib.SimThingComp.CompProperties_ServiceProvider">
        <defaultServiceDefNames>
          <li>Sim_Service_Toilet</li>
        </defaultServiceDefNames>
        <defaultMaxSimultaneousUsers>1</defaultMaxSimultaneousUsers>
        <enabledByDefault>true</enabledByDefault>
      </li>
    </comps>
    <placeWorkers>
      <li>PlaceWorker_PreventInteractionSpotOverlap</li>
    </placeWorkers>
  </ThingDef>
</Defs>
