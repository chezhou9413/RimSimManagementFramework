<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <ThingDef Name="ChequeBase" ParentName="ResourceBase" Abstract="true">
        <thingClass>ThingWithComps</thingClass>
        <statBases>
            <MarketValue>1</MarketValue>
            <Mass>0.01</Mass>
            <MaxHitPoints>100</MaxHitPoints>
            <DeteriorationRate>0</DeteriorationRate>
        </statBases>
        <thingCategories>
            <li>Manufactured</li>
        </thingCategories>
        <stackLimit>75</stackLimit>
        <graphicData>
            <graphicClass>Graphic_Single</graphicClass>
			<drawSize>1.2</drawSize>
        </graphicData>
    </ThingDef>

    <ThingDef ParentName="ChequeBase">
        <defName>Sim_1000Cheque</defName>
        <label>1,000银支票</label>
        <description>一张面值为1,000银的支票，在普通人眼里与废纸无异，但却能在银行里兑换1,000银</description>
        <graphicData>
			<texPath>Things/Item/Cheque/1000Cheque</texPath>
		</graphicData>
    </ThingDef>

