    <ThingDef ParentName="LampBase">
        <defName>Sim_SignBoard1A</defName>
        <label>招牌1A</label>
        <description>招牌1A</description>
        <rotatable>false</rotatable>
        <defaultPlacingRot>South</defaultPlacingRot>
        <graphicData>
            <texPath>Things/Building/SignBoard/SignBoardA/SignBoard1A</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawOffset>(0,0,0.52)</drawOffset>
            <drawSize>(2.0,2.5)</drawSize>
            <damageData>
                <enabled>false</enabled>
            </damageData>
        </graphicData>
        <uiIconPath>Things/Building/SignBoard/SignBoardA/SignBoard1A</uiIconPath>
        <drawerType>MapMeshAndRealTime</drawerType>
        <altitudeLayer>BuildingOnTop</altitudeLayer>
        <costList>
          <Steel>15</Steel>
        </costList>
        <statBases>
          <WorkToBuild>330</WorkToBuild>
          <MaxHitPoints>35</MaxHitPoints>
          <Mass>2</Mass>
        </statBases>
        <designationCategory>SimManagementBuildings</designationCategory>
        <size>(1,1)</size>
        <uiOrder>2991</uiOrder>
        <passability>Standable</passability>
        <terrainAffordanceNeeded IsNull="True" />
        <pathCost>0</pathCost>
        <overrideMinifiedRot>North</overrideMinifiedRot>
        <minifiedDrawOffset>(0, 0, 0.2)</minifiedDrawOffset>
        <building>
          <isEdifice>false</isEdifice>
          <isAttachment>true</isAttachment>
        </building>
        <placeWorkers>
          <li>Placeworker_AttachedToWall</li>
        </placeWorkers>
        <comps>
          <li Class="CompProperties_Power">
            <compClass>CompPowerTrader</compClass>
            <basePowerConsumption>30</basePowerConsumption>
            <powerUpgrades>
              <li>
                <researchProject>ColoredLights</researchProject>
                <factor>0.5</factor>
              </li>
            </powerUpgrades>
          </li>
          <li Class="CompProperties_Styleable" />
          <li Class="CompProperties_Glower">
            <glowRadius>11</glowRadius>
            <glowColor>(214,148,94,0)</glowColor>
            <colorPickerEnabled>true</colorPickerEnabled>
            <darklightToggle>true</darklightToggle>
          </li>
          <li Class="SimManagementLib.SimThingComp.CompProperties_CustomSign" />
        </comps>
    </ThingDef>

