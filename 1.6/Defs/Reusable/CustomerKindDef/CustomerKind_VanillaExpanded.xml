    <arrivalCurve>
      <points>
        <li>(0, 0.1)</li>
        <li>(7, 0.7)</li>
        <li>(12, 1.35)</li>
        <li>(18, 1.1)</li>
        <li>(24, 0.15)</li>
      </points>
    </arrivalCurve>

    <baseMtbDays>0.22</baseMtbDays>
    <budgetRange>700~1800</budgetRange>
    <queuePatienceRange>1400~3600</queuePatienceRange>
    <activeHourRange>7~21</activeHourRange>

    <allowedWeathers>
      <li>Clear</li>
      <li>Fog</li>
      <li>Rain</li>
