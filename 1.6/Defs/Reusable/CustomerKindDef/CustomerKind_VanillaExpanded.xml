  <SimManagementLib.SimDef.CustomerKindDef>
    <defName>SimCustomer_WorkdayOffice</defName>
    <label>通勤白领顾客</label>

    <pawnKindDefs>
      <li>Villager</li>
      <li>Town_Trader</li>
      <li>Town_Councilman</li>
      <li>SpaceRefugee_Clothed</li>
