<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!--
    原版人类顾客的示范表情配置。
    现在表情系统只支持头像贴图，不支持文字 / emoji 字符。
    下面这套默认头像贴图来自 Twemoji，已下载到：
    Textures/CustomerExpressions/Emoji/

    其他种族作者可选两种接入方式：

    1. 直接按种族配置：
       <targetRaceDefs>
         <li>YourRaceDefName</li>
       </targetRaceDefs>

    2. 给自己的 ThingDef / PawnKindDef 打标签，再按标签匹配：
       <modExtensions>
         <li Class="SimManagementLib.SimDef.CustomerExpressionTagExtension">
           <expressionTags>
             <li>anime</li>
             <li>maid_cafe</li>
           </expressionTags>
         </li>
       </modExtensions>
  -->
  <SimManagementLib.SimDef.CustomerExpressionSetDef>
    <defName>SimShopExpression_VanillaHumanEmoji</defName>
    <label>vanilla human emoji portrait expressions</label>
    <priority>10</priority>
    <targetRaceDefs>
      <li>Human</li>
    </targetRaceDefs>
    <requiredTags>
      <li>humanlike</li>
    </requiredTags>
    <expressions>
      <li>
        <eventId>arrival</eventId>
        <iconTexPath>CustomerExpressions/Emoji/arrival-shopping-bags</iconTexPath>
        <chance>0.65</chance>
        <cooldownTicks>300</cooldownTicks>
        <popupScale>1.15</popupScale>
      </li>
      <li>
        <eventId>browse_start</eventId>
        <iconTexPath>CustomerExpressions/Emoji/browse-eyes</iconTexPath>
        <chance>0.45</chance>
        <cooldownTicks>180</cooldownTicks>
        <popupScale>1.15</popupScale>
      </li>
      <li>
        <eventId>browse_wait</eventId>
        <iconTexPath>CustomerExpressions/Emoji/browse-wait-dizzy</iconTexPath>
        <chance>0.35</chance>
        <cooldownTicks>240</cooldownTicks>
        <popupScale>1.15</popupScale>
      </li>
      <li>
        <eventId>browse_no_match</eventId>
        <iconTexPath>CustomerExpressions/Emoji/browse-no-match-confused</iconTexPath>
        <chance>0.75</chance>
        <cooldownTicks>180</cooldownTicks>
        <popupScale>1.15</popupScale>
      </li>
      <li>
        <eventId>purchase_item</eventId>
        <iconTexPath>CustomerExpressions/Emoji/purchase-item-smile</iconTexPath>
        <chance>0.55</chance>
        <cooldownTicks>120</cooldownTicks>
        <popupScale>1.15</popupScale>
      </li>
      <li>
        <eventId>purchase_preferred_item</eventId>
        <iconTexPath>CustomerExpressions/Emoji/purchase-favorite-heart-eyes</iconTexPath>
        <chance>0.85</chance>
        <cooldownTicks>120</cooldownTicks>
        <popupScale>1.2</popupScale>
      </li>
      <li>
        <eventId>purchase_combo</eventId>
        <iconTexPath>CustomerExpressions/Emoji/purchase-combo-star-eyes</iconTexPath>
        <chance>0.85</chance>
        <cooldownTicks>120</cooldownTicks>
        <popupScale>1.2</popupScale>
      </li>
      <li>
        <eventId>checkout_queue_start</eventId>
        <iconTexPath>CustomerExpressions/Emoji/checkout-queue-money</iconTexPath>
        <chance>0.45</chance>
        <cooldownTicks>180</cooldownTicks>
        <popupScale>1.15</popupScale>
      </li>
      <li>
        <eventId>checkout_service_start</eventId>
        <iconTexPath>CustomerExpressions/Emoji/checkout-service-receipt</iconTexPath>
        <chance>0.55</chance>
        <cooldownTicks>180</cooldownTicks>
        <popupScale>1.15</popupScale>
      </li>
      <li>
        <eventId>checkout_paid</eventId>
        <iconTexPath>CustomerExpressions/Emoji/checkout-paid-happy</iconTexPath>
        <chance>0.8</chance>
        <cooldownTicks>180</cooldownTicks>
        <popupScale>1.15</popupScale>
      </li>
      <li>
        <eventId>checkout_timeout</eventId>
        <iconTexPath>CustomerExpressions/Emoji/checkout-timeout-huff</iconTexPath>
        <chance>0.95</chance>
        <cooldownTicks>180</cooldownTicks>
        <popupScale>1.2</popupScale>
      </li>
      <li>
        <eventId>dine_start</eventId>
        <iconTexPath>CustomerExpressions/Emoji/dine-start-plate</iconTexPath>
        <chance>0.7</chance>
        <cooldownTicks>240</cooldownTicks>
        <popupScale>1.2</popupScale>
      </li>
      <li>
        <eventId>dine_finish</eventId>
        <iconTexPath>CustomerExpressions/Emoji/dine-finish-yum</iconTexPath>
        <chance>0.85</chance>
        <cooldownTicks>240</cooldownTicks>
        <popupScale>1.2</popupScale>
      </li>
      <li>
        <eventId>drug_use_start</eventId>
        <iconTexPath>CustomerExpressions/Emoji/browse-wait-dizzy</iconTexPath>
        <chance>0.8</chance>
        <cooldownTicks>240</cooldownTicks>
        <popupScale>1.2</popupScale>
      </li>
      <li>
        <eventId>drug_use_finish</eventId>
        <iconTexPath>CustomerExpressions/Emoji/purchase-favorite-heart-eyes</iconTexPath>
        <chance>0.9</chance>
        <cooldownTicks>240</cooldownTicks>
        <popupScale>1.2</popupScale>
      </li>
    </expressions>
  </SimManagementLib.SimDef.CustomerExpressionSetDef>
</Defs>
