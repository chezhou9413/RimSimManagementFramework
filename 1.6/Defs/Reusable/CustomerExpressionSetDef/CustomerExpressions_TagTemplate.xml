<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!--
    纯头像表情模板。
    复制后把 requiredTags / iconTexPath 改成自己的种族或主题资源。
  -->
  <SimManagementLib.SimDef.CustomerExpressionSetDef Name="SimShopExpression_TaggedTemplate" Abstract="True">
    <priority>100</priority>
    <requiredTags>
      <li>anime</li>
    </requiredTags>
    <expressions>
      <li>
        <eventId>browse_start</eventId>
        <iconTexPath>YourMod/Expressions/browse-curious</iconTexPath>
        <chance>0.6</chance>
        <cooldownTicks>180</cooldownTicks>
        <popupScale>1.25</popupScale>
      </li>
      <li>
        <eventId>purchase_preferred_item</eventId>
        <iconTexPath>YourMod/Expressions/favorite-happy</iconTexPath>
        <chance>0.9</chance>
        <cooldownTicks>120</cooldownTicks>
        <popupScale>1.3</popupScale>
      </li>
    </expressions>
  </SimManagementLib.SimDef.CustomerExpressionSetDef>
</Defs>
